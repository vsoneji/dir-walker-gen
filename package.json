{
    "name": "dir-walker-gen",
    "version": "1.0.1",
    "description": "A javascript generator pattern for directlry listing",
    "main": "src/dir-walker-gen.js",
    "files": [
        "src/"
    ],
    "engines": {
        "node": ">=22"
    },
    "directories": {
        "test": "test",
        "lib": "src"
    },
    "scripts": {
        "test": "mocha test/**/*.test.js",
        "test:ci": "npm test",
