    "license": "MIT",
    "bugs": {
        "url": "https://github.com/vsoneji/dir-walker-gen/issues"
    },
    "homepage": "https://github.com/vsoneji/dir-walker-gen#readme",
    "overrides": {
        "diff": "^8.0.3",
        "serialize-javascript": "^7.0.5"
    },
    "devDependencies": {
        "mocha": "^11.1.0",
        "should": "^13.2.3"
    }
